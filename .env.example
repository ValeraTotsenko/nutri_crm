# =============================================
# NutriBot CRM — Конфигурация
# Скопируй в .env и заполни свои значения
# =============================================

# --- База данных ---
POSTGRES_DB=nutricrm
POSTGRES_USER=nutricrm
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_URL=postgresql://nutricrm:CHANGE_ME_STRONG_PASSWORD_HERE@postgres:5432/nutricrm

# --- Telegram Bot ---
BOT_TOKEN=
OWNER_TELEGRAM_ID=
WEBAPP_URL=https://yourdomain.com

# --- Backend ---
PORT=3000
NODE_ENV=production
TZ=Europe/Kyiv

# --- Уведомления ---
NOTIFICATIONS_HOUR=10
NOTIFICATIONS_TZ=Europe/Kyiv

# --- Backup (для скачивания с удалённого сервера) ---
BACKUP_SSH_USER=
BACKUP_SSH_HOST=
BACKUP_REMOTE_PATH=/backups/nutricrm
BACKUP_KEEP_DAYS=30
